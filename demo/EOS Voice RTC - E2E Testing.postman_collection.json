							"listen": "test",
							"script": {
								"exec": [
									"// Parse response",
									"var jsonData = pm.response.json();",
									"",
									"// Test: Check if response is successful",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has clientBaseUrl\", function () {",
									"    pm.expect(jsonData.clientBaseUrl).to.exist;",
									"});",
									"",
									"pm.test(\"Response has token\", function () {",
									"    pm.expect(jsonData.token).to.exist;",
									"});",
									"",
									"pm.test(\"Channel type is PARTY\", function () {",
									"    pm.expect(jsonData.channelType).to.equal(\"PARTY\");",
									"});",
									"",
									"pm.test(\"Response has roomId\", function () {",
									"    pm.expect(jsonData.roomId).to.exist;",
									"});",
									"",
									"// Cache the room_id for revocation",
									"if (jsonData.roomId) {",
									"    pm.collectionVariables.set(\"party_room_id\", jsonData.roomId);",
									"    console.log(\"✓ Party room ID cached: \" + jsonData.roomId);",
