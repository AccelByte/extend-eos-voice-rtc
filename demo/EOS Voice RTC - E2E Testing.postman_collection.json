{
	"info": {
		"_postman_id": "21eb5066-c35e-4d47-8671-3a0d146420f9",
		"name": "EOS Voice RTC - E2E Testing",
		"description": "End-to-end testing collection for EOS Voice RTC Service Extension.\n\n**Test Flow:**\n1. User Login (Email/Password) → Get User Token\n2. Generate Voice Tokens (Party/Team/Session) using User Token\n3. Admin Login (Client Credentials) → Get Admin Token\n4. Revoke Voice Tokens using Admin Token\n\n**Setup Required:**\n- Update environment variables in Postman\n- Ensure service is running at http://localhost:8000\n- Have valid AccelByte credentials\n- User must be in a party/session for token generation",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "21432124"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "1.1 User Login (Email/Password)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Parse response",
									"var jsonData = pm.response.json();",
									"",
									"// Test: Check if response is successful",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has access_token\", function () {",
									"    pm.expect(jsonData.access_token).to.exist;",
									"});",
									"",
									"pm.test(\"Response has user_id\", function () {",
									"    pm.expect(jsonData.user_id).to.exist;",
									"});",
									"",
									"// Cache the user access token",
									"if (jsonData.access_token) {",
									"    pm.collectionVariables.set(\"user_access_token\", jsonData.access_token);",
									"    console.log(\"✓ User access token cached\");",
									"}",
									"",
									"// Cache the user ID",
									"if (jsonData.user_id) {",
									"    pm.collectionVariables.set(\"user_id\", jsonData.user_id);",
									"    console.log(\"✓ User ID cached: \" + jsonData.user_id);",
									"}",
									"",
									"// Cache namespace if present",
									"if (jsonData.namespace) {",
									"    pm.collectionVariables.set(\"namespace\", jsonData.namespace);",
									"    console.log(\"✓ Namespace cached: \" + jsonData.namespace);",
									"}"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{
									"key": "username",
									"value": "{{client_id}}",
									"type": "string"
								},
								{
									"key": "password",
									"value": "{{client_secret}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "grant_type",
									"value": "password",
									"type": "text"
								},
								{
									"key": "username",
									"value": "{{user_email}}",
									"description": "User email",
									"type": "text"
								},
								{
									"key": "password",
									"value": "{{user_password}}",
									"description": "User password",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/iam/v3/oauth/token",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"iam",
								"v3",
								"oauth",
								"token"
							]
						},
						"description": "Login with email and password to get user access token. User doesn't have data of epic PUID in accelbyte. This user must has logged in Epic using AccelByte token.\n\n**Sets:**\n\n- `user_access_token` - Used for voice token generation\n    \n- `user_id` - User identifier\n    \n- `namespace` - Namespace for the user"
					},
					"response": []
				},
				{
					"name": "1.2 Admin Login (Client Credentials)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Parse response",
									"var jsonData = pm.response.json();",
									"",
									"// Test: Check if response is successful",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has access_token\", function () {",
									"    pm.expect(jsonData.access_token).to.exist;",
									"});",
									"",
									"// Cache the admin access token",
									"if (jsonData.access_token) {",
									"    pm.collectionVariables.set(\"admin_access_token\", jsonData.access_token);",
									"    console.log(\"✓ Admin access token cached\");",
									"}"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{
									"key": "username",
									"value": "{{admin_client_id}}",
									"type": "string"
								},
								{
									"key": "password",
									"value": "{{admin_client_secret}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "grant_type",
									"value": "client_credentials",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/iam/v3/oauth/token",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"iam",
								"v3",
								"oauth",
								"token"
							]
						},
						"description": "Admin login using client credentials flow.\n\n**Sets:**\n- `admin_access_token` - Used for admin operations like token revocation"
					},
					"response": []
				}
			],
			"description": "Authentication requests to obtain user and admin tokens"
		},
